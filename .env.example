# Copy to .env and fill in ONE of the provider sections.
# LLM_PROVIDER is auto-detected from whichever key is present.
# If no key is set, insights fall back to deterministic rule-based mode.

# ── Option A: Anthropic (Claude) ──────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── Option B: Groq (free tier — Llama 3.1 70B) ───────────────────────────────
# Sign up at console.groq.com — free, no credit card needed
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.1-70b-versatile   # optional, this is the default

# ── Option C: Ollama (fully local, 100% free, no account needed) ─────────────
# 1. Download installer: https://ollama.com/download/windows
# 2. Pull a model (pick one):
#      ollama pull phi3        # 2.3 GB — fast, works on CPU-only PCs
#      ollama pull llama3.1    # 4.7 GB — better quality, needs more RAM
# 3. Set the model name below; OLLAMA_HOST is auto-detected if Ollama is running
# OLLAMA_MODEL=phi3
# OLLAMA_HOST=http://localhost:11434    # default, only needed if running remotely

# ── Override provider explicitly (optional) ───────────────────────────────────
# LLM_PROVIDER=groq   # anthropic | groq | ollama | rule_based
